// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STUDENT
  TEACHER
  USER // New role for unassigned public visitors
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

// --- Core Auth Models ---

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?   // For profile photo
  role          Role      @default(USER) // Default for public visitors
  phone         String?   @unique
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // Profiles
  student       Student?
  teacher       Teacher?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// --- Business Domain Models ---
enum StudentStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model Student {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId   String?  @unique // Assigned by Manager (e.g., STU-2026-001)
  status      StudentStatus @default(PENDING)
  
  college     String?
  address     String?
  guardianName String?
  guardianPhone String?
  
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])
  
  enrollments Enrollment[]
  results     Result[]
  attendance  Attendance[]
  payments    Payment[]

  @@map("student")
}

model Teacher {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId   String?  @unique // Assigned by Manager (e.g., TEA-2026-001)
  specialization String?
  experience    String?
  qualification String?
  description   String? // Optional teaching description / bio for public site
  salary        Decimal?
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE

  batches     Batch[] 
  notices     Notice[] 

  @@map("teacher")
}

model Group {
  id          String    @id @default(cuid())
  name        String    @unique // Science, Commerce, Arts
  description String?
  
  subjects    Subject[]
  students    Student[] // Default group for students
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("group")
}

model Subject {
  id          String   @id @default(cuid())
  name        String   
  code        String   @unique
  description String?
  
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])
  
  batches     Batch[]

  @@map("subject")
}

model Batch {
  id          String   @id @default(cuid())
  name        String   // e.g., "Batch A - Evening"
  startTime   String?
  endTime     String?
  days        String?  // e.g., "Sun,Tue,Thu"
  
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  
  enrollments Enrollment[]
  exams       Exam[]
  attendance  Attendance[]

  @@map("batch")
}

model Enrollment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id])
  
  enrolledAt  DateTime @default(now())
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, DROPPED

  @@unique([studentId, batchId])
  @@map("enrollment")
}

model Payment {
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id])
  amount      Decimal
  status      PaymentStatus @default(PENDING)
  method      String?       // bKash, Nagad, Cash, Bank
  transactionId String?    @unique
  month       String?       // Monthly fee for which month
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  @@map("payment")
}

model Exam {
  id          String   @id @default(cuid())
  title       String   // e.g., "Mid Term"
  date        DateTime
  maxMarks    Int
  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id])
  
  results     Result[]

  @@map("exam")
}

model Result {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id])
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  
  marksObtained Int
  remarks     String?
  
  @@unique([examId, studentId])
  @@map("result")
}

model Attendance {
  id          String           @id @default(cuid())
  date        DateTime         @default(now())
  status      AttendanceStatus @default(PRESENT)
  
  studentId   String
  student     Student          @relation(fields: [studentId], references: [id])
  
  batchId     String
  batch       Batch            @relation(fields: [batchId], references: [id])

  @@map("attendance")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isGlobal    Boolean  @default(true)
  
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notice")
}
